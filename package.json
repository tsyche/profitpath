{
  "name": "profitpath",
  "version": "0.8.24-beta",
  "description": "A lightweight client-side simulator for recurring service businesses",
  "type": "module",
  "main": "assets/app.jsx",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run src/",
    "test:e2e": "playwright test --reporter=list",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "lint": "eslint assets src tests public",
    "lint:fix": "eslint assets src tests public --fix",
    "postinstall": "find node_modules/@capacitor -name build.gradle -type f -exec sed -i.bak \"s/proguard-android\\.txt/proguard-android-optimize.txt/g\" {} \\; && find node_modules/@capacitor -name '*.bak' -delete 2>/dev/null || true"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.0",
    "@capacitor/core": "^5.7.8",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@vitejs/plugin-legacy": "^8.0.2",
    "@vitest/ui": "^4.0.18",
    "eslint": "^10.1.0",
    "jsdom": "^28.1.0",
    "typescript": "^5.0.0",
    "vite": "^8.0.16",
    "vitest": "^4.0.18"
  },
  "keywords": [
    "business",
    "simulator",
    "profitability",
    "service-business",
    "pwa"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@capacitor/android": "^5.7.8",
    "@capacitor/ios": "^5.7.8",
    "@capacitor/keyboard": "^5.0.9",
    "@capacitor/splash-screen": "^5.0.8",
    "@capacitor/status-bar": "^5.0.8"
  }
}
