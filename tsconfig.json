{
  "compilerOptions": {
    "target": "ES2017",
    "module": "ESNext",
    "lib": ["ES2017", "DOM"],
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "dist",
    "rootDir": "assets",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": [
    "assets/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
